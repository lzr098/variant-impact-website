# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── LLM Translation (for UniProt function description translation) ──
# Optional. If unset, falls back to built-in dictionary translation.
LLM_ENDPOINT=             # OpenAI-compatible chat completions URL (default: https://api.openai.com/v1/chat/completions)
LLM_API_KEY=              # API key for LLM endpoint
LLM_MODEL=                # Model name (default: gpt-4o-mini)
